---
import { NAV, SITE } from "../consts";
import { useTranslations } from "../i18n/ui";

const t = useTranslations("en");
// Normalize the path (drop trailing slash) and pick the single most specific
// matching nav item, so a deep link like /resources/understanding-ai lights up
// "AI" and not also "Resources".
const path = (Astro.url.pathname.replace(/\/$/, "") || "/");
const matches = NAV.filter((i) =>
  i.href === "/" ? path === "/" : path === i.href || path.startsWith(i.href + "/"),
);
const activeHref = matches.length
  ? matches.reduce((a, b) => (b.href.length > a.href.length ? b : a)).href
  : null;
---

<header class="site-header">
  <div class="wrap header-inner">
    <a href="/" class="brand" aria-label={`${SITE.name}, home`}>
      <span class="brand-mark" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="3.1" fill="currentColor" />
          <path
            d="M12 9V3M12 15v6M9.2 10.3 4.5 6.6M14.8 13.7l4.7 3.7M9.2 13.7 4.5 17.4M14.8 10.3l4.7-3.7"
            stroke="currentColor"
            stroke-width="1.4"
            stroke-linecap="round"
          />
          <circle cx="4.5" cy="6.6" r="1.5" fill="currentColor" />
          <circle cx="19.5" cy="17.4" r="1.5" fill="currentColor" />
          <circle cx="4.5" cy="17.4" r="1.5" fill="currentColor" />
          <circle cx="19.5" cy="6.6" r="1.5" fill="currentColor" />
        </svg>
      </span>
      <span class="brand-text">{SITE.shortName}</span>
    </a>

    <nav aria-label="Primary">
      <input type="checkbox" id="nav-toggle" class="nav-toggle" />
      <label for="nav-toggle" class="nav-burger" aria-hidden="true">
        <span></span><span></span><span></span>
      </label>
      <ul class="nav-list">
        {
          NAV.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={["nav-link", { active: item.href === activeHref }]}
                aria-current={item.href === activeHref ? "page" : undefined}
              >
                {t(item.key)}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--color-paper) 88%, transparent);
    backdrop-filter: saturate(140%) blur(8px);
    border-bottom: 1px solid var(--color-line);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4.25rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--color-ink);
  }
  .brand:hover { color: var(--color-pine-deep); }
  .brand-mark { color: var(--color-pine); display: inline-flex; }
  .brand-text {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.2rem;
    letter-spacing: -0.01em;
    font-variation-settings: "opsz" 30;
  }
  .nav-list {
    display: flex;
    align-items: center;
    gap: 1.6rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-link {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-ink-soft);
    text-decoration: none;
    padding: 0.3rem 0;
    border-bottom: 2px solid transparent;
    transition: color 0.16s var(--ease-out), border-color 0.16s var(--ease-out);
  }
  .nav-link:hover { color: var(--color-ink); }
  .nav-link.active {
    color: var(--color-pine-deep);
    border-bottom-color: var(--color-pine);
  }
  .nav-toggle, .nav-burger { display: none; }

  @media (max-width: 760px) {
    .nav-burger {
      display: inline-flex;
      flex-direction: column;
      gap: 4px;
      width: 2.4rem;
      height: 2.4rem;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      border: 1px solid var(--color-line-strong);
      border-radius: 0.5rem;
    }
    .nav-burger span {
      width: 18px;
      height: 2px;
      background: var(--color-ink);
      transition: transform 0.2s var(--ease-out), opacity 0.2s var(--ease-out);
    }
    .nav-list {
      position: absolute;
      top: 4.25rem;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      background: var(--color-paper);
      border-bottom: 1px solid var(--color-line);
      padding: 0.5rem 1.5rem 1rem;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.25s var(--ease-out);
    }
    .nav-list li { width: 100%; }
    .nav-link {
      display: block;
      padding: 0.75rem 0;
      width: 100%;
      border-bottom: 1px solid var(--color-line);
    }
    .nav-toggle:checked ~ .nav-list { max-height: 22rem; }
    .nav-toggle:checked ~ .nav-burger span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
    .nav-toggle:checked ~ .nav-burger span:nth-child(2) { opacity: 0; }
    .nav-toggle:checked ~ .nav-burger span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }
  }
</style>

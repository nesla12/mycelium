---
import Base from "../layouts/Base.astro";
import Boundary from "../components/Boundary.astro";
import { SITE } from "../consts";

const principles = [
  {
    title: "Build the human before the skill",
    body: "A mind is built on a body and a bond. Sleep, movement, play, language, and a present adult are the construction materials, not the extras. So they come first, and everything academic is built on top of them.",
  },
  {
    title: "The child does the thinking",
    body: "Learning is the residue of mental effort: a child grows from what they actively think about, not from what passes in front of them. So anything that does the thinking for the child, a screen, an adult, or an AI, is removed, because it removes the very thing that teaches.",
  },
  {
    title: "Knowledge before skill",
    body: "You cannot think critically, solve problems, or create in a vacuum. Judgment and creativity run on a deep base of knowledge held in memory. So we build the knowledge first, and the higher abilities become possible.",
  },
  {
    title: "Meet the child where they are",
    body: "A child learns at the edge of what they already know, so teaching aimed at the curriculum or the top of the class leaves most of the room behind. We find each child's actual level and move them forward from there.",
  },
  {
    title: "Hard but achievable",
    body: "Too easy is boring and too hard is defeating. Learning and curiosity live in effortful success, the difficulty a child can reach by trying. So we aim there on purpose, rather than at comfort.",
  },
  {
    title: "Take what works, from anywhere",
    body: "Good intentions and tradition are not evidence. We use the strongest global evidence on how humans actually learn, and we drop what is merely fashionable or familiar, however beloved, because the child's development is what is at stake.",
  },
];
---

<Base
  title="Principles"
  description="The constitutional beliefs of the Human-Core Initiative, and the boundary that holds everywhere."
>
  <section class="wrap intro">
    <p class="eyebrow rise rise-1">Principles</p>
    <h1 class="rise rise-2">What we believe.</h1>
    <p class="lede rise rise-3">
      These six principles are constitutional. Each is a short rule you can hold
      in your head and use to judge a decision. They are the test every
      contribution must pass, and they cannot be overridden by contribution,
      funding, or convenience.
    </p>
  </section>

  <section class="wrap principles">
    <ol class="principle-list">
      {
        principles.map((p, i) => (
          <li class="principle">
            <span class="section-no">{String(i + 1).padStart(2, "0")}</span>
            <div>
              <h2>{p.title}</h2>
              <p>{p.body}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="wrap commitments">
    <p class="eyebrow">Two commitments</p>
    <p class="commitments-lede">
      Alongside the principles, two promises hold. They are commitments, not
      learning principles, but they are just as binding.
    </p>
    <div class="commitment-grid">
      <div class="commitment">
        <h2>Free and open, forever</h2>
        <p>
          The curriculum and documentation are free, forkable, and translatable,
          owned by no company and adoptable by anyone on earth. Derivatives stay
          open.
        </p>
      </div>
      <div class="commitment">
        <h2>The boundary</h2>
        <p>
          Our tools serve the human. We never build systems that infer the
          emotional or inner states of children. It holds everywhere, and it is
          the project's signature.
        </p>
      </div>
    </div>
  </section>

  <section class="wrap boundary-wrap">
    <Boundary />
  </section>

  <section class="wrap guardrails">
    <div class="callout">
      <h2>What the teacher tool must never do</h2>
      <p>
        Pillar 2 puts an AI coach in the hands of teachers. By constitution,
        that tool must never infer a child's emotion or inner state; never
        score, rank, or profile children; and never replace the teacher's
        relationship with the child. It is owned by the teacher and private to
        the teacher. The moment it becomes a dashboard for administrators to
        monitor staff, it stops being coaching and becomes surveillance. Its
        data belongs to the person being developed, not to the institution.
      </p>
    </div>
    <p class="more">
      Read the full <a href={`${SITE.repo}/blob/main/CONSTITUTION.md`}>Constitution</a>,
      including the guardrails for children's AI work and the governance and
      evidence standards.
    </p>
  </section>
</Base>

<style>
  .intro { padding-top: 3.5rem; max-width: 46rem; }
  .intro h1 { font-size: clamp(2.4rem, 5.5vw, 3.6rem); margin: 0.6rem 0 0; }
  .lede {
    font-size: 1.2rem;
    line-height: 1.55;
    color: var(--color-ink-soft);
    margin-top: 1.2rem;
  }
  .principles { margin-top: 3rem; }
  .principle-list { list-style: none; margin: 0; padding: 0; }
  .principle {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.5rem;
    padding: 2rem 0;
    border-top: 1px solid var(--color-line);
    align-items: start;
  }
  .principle:last-child { border-bottom: 1px solid var(--color-line); }
  .principle h2 {
    font-size: clamp(1.35rem, 2.6vw, 1.7rem);
    margin: 0 0 0.6rem;
    max-width: 32ch;
  }
  .principle p { margin: 0; color: var(--color-ink-soft); max-width: 52rem; }

  .commitments { margin-top: 4rem; max-width: 60rem; }
  .commitments-lede { color: var(--color-ink-soft); margin: 0.5rem 0 0; max-width: 44rem; }
  .commitment-grid {
    display: grid;
    gap: 1.5rem;
    margin-top: 1.8rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 700px) { .commitment-grid { grid-template-columns: 1fr 1fr; } }
  .commitment {
    border: 1px solid var(--color-line);
    border-left: 3px solid var(--color-pine);
    border-radius: 0.6rem;
    padding: 1.4rem 1.5rem;
    background: var(--color-card);
  }
  .commitment h2 { font-size: 1.2rem; margin: 0 0 0.5rem; }
  .commitment p { margin: 0; color: var(--color-ink-soft); font-size: 0.98rem; }

  .boundary-wrap { margin-top: 4rem; }

  .guardrails { margin-top: 3.5rem; max-width: 52rem; }
  .guardrails h2 { font-size: 1.3rem; margin: 0 0 0.7rem; }
  .guardrails .callout p { margin: 0; color: var(--color-ink-soft); }
  .more { margin-top: 1.6rem; color: var(--color-ink-soft); }
</style>

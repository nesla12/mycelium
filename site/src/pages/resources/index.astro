---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import ResourceCard from "../../components/ResourceCard.astro";

const docs = await getCollection("resources");
// Lead with the Pillar 3 Teacher Workbook (featured), then the rest in order.
const sorted = docs.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return a.data.order - b.data.order;
});
const href = (slug: string) => `/resources/${slug}`;
---

<Base
  title="Resources"
  description="Free, downloadable workbooks and guides. No signup, no email gate. Each document renders here and downloads as Markdown."
>
  <section class="wrap intro">
    <p class="eyebrow rise rise-1">Resources</p>
    <h1 class="rise rise-2">Free to use, adapt, translate, and fork.</h1>
    <p class="lede rise rise-3">
      Everything below is open and free. No signup, no email gate. Read each
      document here, or download the Markdown and take it into your classroom,
      your school, or your own fork.
    </p>
    <p class="note rise rise-3">
      Start with the curriculum: it is the spine of the framework, covering
      birth to twelve. The Pillar 3 workbook is the AI-mastery capstone for ages
      ten and up, and the most ready-to-run module if you want to begin
      teaching tomorrow.
    </p>
  </section>

  <section class="wrap grid rise rise-4">
    {
      sorted.map((doc) => (
        <ResourceCard
          href={href(doc.data.slug)}
          title={doc.data.title}
          subtitle={doc.data.subtitle}
          summary={doc.data.summary}
          audience={doc.data.audience}
          pillar={doc.data.pillar}
          featured={doc.data.featured}
        />
      ))
    }
  </section>
</Base>

<style>
  .intro { padding-top: 3.5rem; max-width: 48rem; }
  .intro h1 { font-size: clamp(2.2rem, 5vw, 3.2rem); margin: 0.6rem 0 0; }
  .lede {
    font-size: 1.2rem;
    line-height: 1.55;
    color: var(--color-ink-soft);
    margin-top: 1.2rem;
  }
  .note {
    margin-top: 1rem;
    color: var(--color-ink-soft);
    font-size: 1rem;
    border-left: 3px solid var(--color-pine);
    padding-left: 1rem;
  }
  .grid {
    margin-top: 3rem;
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 680px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
